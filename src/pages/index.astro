---
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';
import { hero } from '~/i18n/translations';

const huggingFaceHref =
  'https://huggingface.co/INSAIT-Institute/MamayLM-Gemma-3-27B-IT-v2.0';

const chatHref = 'https://mamay.ai';
const apiAccessHref = 'mailto:chat.mamay@insait.ai?subject=API%20Access';

const metadata = {
  title: 'MamayLM',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="relative not-prose">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-12 md:pt-20">
        <div class="text-center max-w-5xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold leading-tight tracking-tighter mb-4 font-heading dark:text-gray-200">
            <span data-lang-en style="display:none" set:html={hero.en.title} />
            <span data-lang-uk set:html={hero.uk.title} />
          </h1>
          <p class="text-xl text-muted mb-8 max-w-3xl mx-auto">
            <span data-lang-en style="display:none" set:html={hero.en.subtitle} />
            <span data-lang-uk set:html={hero.uk.subtitle} />
          </p>
          <div data-lang-en style="display:none">
            <div class="flex flex-col sm:flex-row justify-center gap-4">
              <Button variant="primary" text="Try MamayLM Chat" href={chatHref} icon="tabler:message-chatbot" target="_blank" class="w-full sm:w-auto flex-shrink-0 whitespace-nowrap" />
              <Button variant="secondary" text={hero.en.cta} href={apiAccessHref} icon="tabler:api" target="_blank" class="w-full sm:w-auto flex-shrink-0 whitespace-nowrap" />
              <Button variant="secondary" text={hero.en.ctaSecondary} href={huggingFaceHref} icon="tabler:download" target="_blank" class="w-full sm:w-auto flex-shrink-0 whitespace-nowrap" />
            </div>
            <div class="mt-3 text-center">
              <a href="/docs" class="text-sm text-muted hover:text-primary transition-colors">
                Already have an API key? See documentation →
              </a>
            </div>
          </div>
          <div data-lang-uk>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
              <Button variant="primary" text="Чат з MamayLM" href={chatHref} icon="tabler:message-chatbot" target="_blank" class="w-full sm:w-auto flex-shrink-0 whitespace-nowrap" />
              <Button variant="secondary" text={hero.uk.cta} href={apiAccessHref} icon="tabler:api" target="_blank" class="w-full sm:w-auto flex-shrink-0 whitespace-nowrap" />
              <Button variant="secondary" text={hero.uk.ctaSecondary} href={huggingFaceHref} icon="tabler:download" target="_blank" class="w-full sm:w-auto flex-shrink-0 whitespace-nowrap" />
            </div>
            <div class="mt-3 text-center">
              <a href="/docs" class="text-sm text-muted hover:text-primary transition-colors">
                Уже маєте API-ключ? Перегляньте документацію →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
