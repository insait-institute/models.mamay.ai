<script>
  document.querySelectorAll('pre').forEach((pre) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const isUk = pre.closest('[data-lang-uk]') !== null;
    const labelCopy = isUk ? 'Копіювати' : 'Copy';
    const labelDone = isUk ? 'Скопійовано!' : 'Copied!';

    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = labelCopy;
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      await navigator.clipboard.writeText(code?.textContent ?? pre.textContent ?? '');
      btn.textContent = labelDone;
      setTimeout(() => { btn.textContent = labelCopy; }, 1500);
    });
    wrapper.appendChild(btn);
  });
</script>
