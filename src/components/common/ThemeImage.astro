---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  light: ImageMetadata;
  dark: ImageMetadata;
  alt: string;
  class?: string;
  widths?: number[];
  sizes?: string;
}

const {
  light,
  dark,
  alt,
  class: className = '',
  widths = [400, 900],
  sizes = '(max-width: 900px) 400px, 900px',
} = Astro.props;
---

<Image src={light} alt={alt} widths={widths} sizes={sizes} class={`dark:hidden ${className}`} />
<Image src={dark} alt={alt} widths={widths} sizes={sizes} class={`hidden dark:block ${className}`} />
